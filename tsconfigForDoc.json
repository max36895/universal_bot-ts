{
    "compilerOptions": {
        "module": "commonjs",
        "target": "es2023",
        "useDefineForClassFields": true,
        "lib": ["es2023", "dom"],
        "moduleResolution": "node",
        "removeComments": false,
        "sourceMap": false,
        "allowJs": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "noFallthroughCasesInSwitch": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "outDir": "dist",
        "baseUrl": ".",
        "paths": {
            "umbot/plugins": ["src/plugins"],
            "umbot/test": ["src/test"],
            "umbot/build": ["src/build"],
            "umbot/preload": ["src/Preload"],
            "umbot/*": ["src/*"]
        },
        "types": ["node", "jest"],
        "typeRoots": ["node_modules/@types"]
    },
    "includes": ["src/**/*", "cli/**/*"],
    "exclude": ["node_modules", "cli/template/**/*", "tests/**/*", "examples/**/*"]
}
