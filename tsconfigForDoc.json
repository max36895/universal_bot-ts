{
    "compilerOptions": {
        "module": "Node16",
        "target": "ES2023",
        "useDefineForClassFields": true,
        "lib": ["ES2023", "DOM"],
        "moduleResolution": "Node16",
        "removeComments": false,
        "stripInternal": true,
        "sourceMap": false,
        "allowJs": false,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "noFallthroughCasesInSwitch": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "rootDir": "./src",
        "outDir": "./dist",
        "declaration": true,
        "declarationMap": true,
        "types": ["node", "jest"],
        "typeRoots": ["node_modules/@types"],
        "incremental": true,
        "tsBuildInfoFile": "./dist/.tsbuildinfo.typedoc"
    },
    "include": ["src/**/*"],
    "exclude": [
        "node_modules",
        "dist",
        "cli",
        "examples",
        "tests",
        "**/*.test.ts",
        "**/node_modules/**"
    ]
}
