{
    "entryPoints": [
        "src/index.ts",
        "src/build.ts",
        "cli",
        "src/plugins.ts",
        "src/middleware.ts",
        "src/test.ts",
        "src/Preload.ts",
        "src/docs"
    ],
    "entryPointStrategy": "resolve",
    "readme": "README.md",
    "projectDocuments": ["src/docs/*", "cli/README.md"],
    "name": "umbot",
    "out": "./docs/",
    "tsconfig": "tsconfigForDoc.json",
    "excludePrivate": true,
    "excludeExternals": true,
    "excludeInternal": true,
    "excludeReferences": true,
    "theme": "default",
    "includeVersion": true,
    "categorizeByGroup": true,
    "searchInComments": true,
    "sort": ["kind", "instance-first", "alphabetical"],
    "validation": {
        "invalidLink": true,
        "notDocumented": false
    },
    "navigationLinks": {
        "GitHub": "https://github.com/max36895/universal_bot-ts",
        "npm": "https://www.npmjs.com/package/umbot"
    },
    "visibilityFilters": {
        "protected": false,
        "private": false,
        "inherited": true,
        "external": false
    }
}
